    .claim-row:last-child { border-bottom: none; }
    .claim-cell { padding: 10px 12px; }
    .claim-cell-label { font-family: var(--font-mono); font-size: 0.55rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 4px; display: block; }
    .claim-said { color: var(--brick); }
    .claim-data { color: var(--green); }
    .claim-cell:first-child { border-right: 1px solid var(--border); }

    .falsify-box { background: var(--card-face,var(--surface)); border: 1px solid var(--rule,var(--border)); border-left: 3px solid var(--green); border-radius: 4px; padding: 16px 18px; margin: 24px 0; }
