    .table-scroll::after { content: ''; position: absolute; top: 0; right: 0; bottom: 0; width: 24px; background: linear-gradient(to right, transparent, var(--bg,#f7f5f1)); pointer-events: none; opacity: 0; transition: opacity 0.2s; }
    .table-scroll.has-overflow::after { opacity: 0.7; }
