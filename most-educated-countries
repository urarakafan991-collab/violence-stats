    p { margin-bottom: 14px; }
    .inline-link { color: var(--brick); text-decoration: none; }
    .inline-link:hover { text-decoration: underline; }
    hr { border: none; border-top: 1px solid var(--border); margin: 28px 0; }
    .source-note { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-quiet); margin-top: -8px; margin-bottom: 20px; line-height: 1.5; }
