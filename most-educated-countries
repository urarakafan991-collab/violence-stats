    .stat-val.neutral { color: var(--text-head); }
    .stat-val.warn { color: var(--amber); }
    .stat-val.positive::before { content: "\2713\00a0"; font-size: 1.05em; font-weight: 700; }
    .stat-val.negative::before { content: "\2717\00a0"; font-size: 1.05em; font-weight: 700; }
    .stat-val.warn::before { content: "\26A0\00a0"; font-size: 1.05em; font-weight: 700; }
    .stat-val.neutral::before { content: "\2014 "; }

    .data-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; margin: 16px 0; border: 1px solid var(--border); border-radius: 6px; overflow: hidden; }
    .data-table th { background: var(--border); padding: 8px 12px; font-family: var(--font-sans); font-size: 0.7rem; font-weight: 600; text-align: left; color: var(--text-head); }
    .data-table td { padding: 8px 12px; border-bottom: 1px solid var(--border); vertical-align: top; line-height: 1.5; }
    .data-table tr:last-child td { border-bottom: none; }
    .data-table tr:nth-child(even) td { background: var(--surface); }
    [data-theme="dark"] .data-table tr:nth-child(even) td { background: #242220; }
    .td-rate { font-family: var(--font-mono); color: var(--green); font-weight: 700; }
    .td-num { font-family: var(--font-mono); color: var(--text-head); font-weight: 700; }
    .td-note { color: var(--text-dim); font-size: 0.78rem; }
    .td-warn { color: var(--amber); font-weight: 600; }
    .td-alert { color: var(--brick); font-weight: 600; }

    .chart-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: 6px; padding: 16px; margin: 16px 0; }
    [data-theme="dark"] .chart-wrap { background: #2a2826; }
    [data-theme="dark"] .chart-wrap canvas { filter: brightness(0.9) saturate(1.2); }
    .chart-title { font-family: var(--font-sans); font-size: 0.75rem; font-weight: 600; color: var(--text-dim); margin-bottom: 12px; text-transform: uppercase; letter-spacing: .06em; }
    .chart-canvas-wrap { position: relative; height: 260px; }

    .steelman-wrap { border: 1px solid var(--border); border-radius: 6px; overflow: hidden; margin: 16px 0; }
    .steelman-row { display: flex; border-bottom: 1px solid var(--border); font-size: 0.86rem; }
